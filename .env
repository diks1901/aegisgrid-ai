# ============================================================
# AegisGrid AI — Environment Configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to git — it's in .gitignore
# ============================================================

# ── Google Gemini API ────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY= <"ADD YOUR GEMINI API KEY HERE">

# ── AegisGrid API Security Key ───────────────────────────────
# Used to protect your /api/investigate endpoint.
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
AEGISGRID_API_KEY=aegisgrid-dev-key-change-in-prod

# ── Server Configuration ─────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ── Optional: Google Cloud (only needed for Vertex AI deployment) ──
# GOOGLE_CLOUD_PROJECT=your_project_id
# GOOGLE_CLOUD_LOCATION=us-central1
