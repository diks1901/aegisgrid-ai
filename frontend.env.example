# Frontend environment variables for Vite
# Copy this to .env.local (never commit .env.local to git)

# Set to your FastAPI backend URL
# Local dev:  http://localhost:8000
# Deployed:   https://your-aegisgrid-backend.onrender.com
VITE_BACKEND_URL=http://localhost:8000

# Must match AEGISGRID_API_KEY in your backend .env
VITE_API_KEY=aegisgrid-dev-key-change-in-prod
